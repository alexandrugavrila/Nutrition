# Immutable image references (pin by digest or immutable release tag)
BACKEND_IMAGE=ghcr.io/your-org/nutrition-backend:<immutable-tag>
FRONTEND_IMAGE=ghcr.io/your-org/nutrition-frontend:<immutable-tag>
POSTGRES_IMAGE=postgres:13

# Database container credentials (required; inject via secret manager in deployment)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=nutrition

# Backend runtime settings (required secrets should never be committed)
DATABASE_URL=postgresql://<db-user>:<db-password>@db:5432/<db-name>
USDA_API_KEY=
# Comma-separated list (or "*"). For same-origin proxy, keep this to your public frontend origin.
CORS_ALLOW_ORIGINS=https://your-app.example.com
DB_AUTO_CREATE=false

# Public port mapping
PROD_BACKEND_PORT=8000
PROD_FRONTEND_PORT=80
